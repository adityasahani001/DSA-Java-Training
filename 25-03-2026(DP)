Count number of binary strings without consecutive 1's

Code=

public class Main
{   
    public static int countString(int n){
        // base condition
        if(n==0) return 1;
        if(n==1) return 2;
        if(n==2) return 3;
        
        // logic
        return countString(n-1) + countString(n-2);
    }
	public static void main(String[] args) {
	    int n =3;
		System.out.println(countString(n));
	}
}


Q- 198. House Robber

class Solution {

    public static int robFrom(int[] nums, int index){
        // base condition
        if(index >= nums.length)
        return 0;
        // logic
        int include = nums[index]+ robFrom(nums,index + 2);
        int exlcude = robFrom(nums, index +1);
        return Math.max(include, exlcude);

    }
    public int rob(int[] nums) {
        return robFrom(nums,0);
    }
}
